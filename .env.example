# App URL (used by modules that wrap internal API routes)
INTERNAL_API_URL=http://localhost:3000

# NASA FIRMS — thermal hotspot detection
# Get a free key at: https://firms.modaps.eosdis.nasa.gov/api/config/realtime/
FIRMS_KEY=your_firms_key_here

# PostgreSQL with PostGIS (optional — mock data used when absent)
DATABASE_URL=postgresql://user:pass@localhost:5432/satellite_db

# Mapbox (optional — map works without it via GIBS/ESRI/OSM fallbacks)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# ── Module System API Keys (all optional — modules show mock data without keys) ──

# ACLED — Armed Conflict Location & Event Data
ACLED_KEY=
ACLED_EMAIL=

# Sentinel Hub — ESA processed satellite imagery
SENTINEL_HUB_KEY=

# Space-Track — NORAD orbital catalog (register at space-track.org)
SPACE_TRACK_USER=
SPACE_TRACK_PASS=

# FlightLabs / AirLabs — aviation data for BKK/DMK
FLIGHTLABS_KEY=

# Meteoblue — high-resolution weather (100+ variables)
METEOBLUE_KEY=

# Meteosource — hyperlocal weather for Thai cities
METEOSOURCE_KEY=

# PredictHQ — real-world event intelligence
PREDICTHQ_KEY=

# NewsAPI — global news aggregation
NEWS_API_KEY=
